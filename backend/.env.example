# =================================================================
# DATABASE CONFIGURATION
# =================================================================

# High Priority: The full connection string for Production/Cloud.
# If this is set, the app ignores LOCAL_DATABASE_PATH.
# Format: postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=

# Local Development: The relative path from the project root.
# The app will automatically create the folder if it doesn't exist.
# Default: data/dev.db
LOCAL_DATABASE_PATH=data/dev.db


# =================================================================
# INITIAL SYSTEM ADMINISTRATOR
# =================================================================
# These credentials are used by 'setup-db' to create the first 
# SuperAdmin user. Change these before running the initialization.

# The login username (e.g., jdoe)
FIRST_ADMIN_USERNAME=admin

# The contact email for the admin account
FIRST_ADMIN_EMAIL=admin@example.com

# The plain-text password. 
# NOTE: This will be hashed using Bcrypt before being stored in the DB.
FIRST_ADMIN_PASSWORD=SuperSecretPassword123!


# =================================================================
# SECURITY & AUTHENTICATION (Next Phase)
# =================================================================

# Secret key for signing JWT tokens. 
# Generate a secure one using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here

# Token expiration time in minutes (e.g., 60 for 1 hour, 1440 for 1 day)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Algorithm used for JWT signing
ALGORITHM=HS256